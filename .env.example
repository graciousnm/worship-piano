# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ────────────────────────────────────────────
DB_PATH=gospel_piano.db

# ── RSS Sync ────────────────────────────────────────────
# How often to check for new videos (ms). Default: 6 hours
SYNC_INTERVAL_MS=21600000

# ── CORS ────────────────────────────────────────────────
# Set to your domain in production, e.g. https://piano.example.com
# Use * to allow all origins (not recommended)
CORS_ORIGIN=*
